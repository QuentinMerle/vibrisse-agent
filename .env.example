# --- Vibrisse Agent : Configuration Example ---

# [CORE]
# Chemin absolu du dossier de code à analyser (ex: /Users/username/my-project)
TARGET_PROJECT_PATH=.

# [LLM PROVIDER]
# Options: ollama, openai, google, openrouter
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434

# [MODELS]
# Modèle principal pour le chat et la réflexion
LLM_MODEL=gemma4:e2b
# Optionnel: modèles spécifiques pour différentes tâches
LLM_MODEL_ORCHESTRATOR=gemma4:e2b
LLM_MODEL_CODER=gemma4:e2b

# [EVALUATION - RAGAS]
# Note: RAGAS nécessite des modèles plus puissants pour le "jugement" technique.
# Il est recommandé d'utiliser un modèle 8B+ (ex: llama3, gemma2:9b) en local.
RAGAS_MODEL=llama3
RAGAS_EMBEDDING_MODEL=nomic-embed-text

# [API KEYS]
# Récupérez votre clé sur https://tavily.com pour la recherche Web
TAVILY_API_KEY=

# Optionnel: pour les outils GitHub
GITHUB_TOKEN=

# Optionnel: pour utiliser Gemini en Cloud
GOOGLE_API_KEY=

# [FEATURES]
# Activer/Désactiver les outils gourmands ou spécifiques
ENABLE_WEB_SEARCH=true
ENABLE_VISION=true
ENABLE_EXPERT_REVIEW=true

# [SECURITY]
# Masquage automatique des secrets dans les logs (Recommandé)
SECURITY_SCRUBBING_ENABLED=true
APP_DEBUG=false
